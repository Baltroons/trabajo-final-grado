{% extends 'base.html.twig' %}

{% block title %}Inicio - TareasApp{% endblock %}

{% block body %}
    <div class="bg-white rounded-xl shadow-md p-6 border-t-4 border-emerald-500">

        <h1 class="text-3xl font-bold text-emerald-800 mb-2">{{ mensaje }}</h1>
        <p class="text-emerald-600 mb-8 border-b pb-4">Tu entorno está funcionando, hablando con PostgreSQL y ahora... ¡se ve increíble!</p>

        <div class="mb-4">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Mis Tareas:</h2>

            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {% for tarea in tareas %}
                    <div class="p-4 border border-emerald-100 bg-emerald-50/50 rounded-lg flex items-start space-x-3 hover:shadow-lg transition-shadow hover:border-emerald-300">
                        <div class="bg-emerald-500 text-white rounded-full w-8 h-8 flex items-center justify-center font-bold flex-shrink-0 shadow-sm">
                            {{ tarea.getId() }}
                        </div>
                        <div class="text-gray-700 font-medium pt-1">
                            {{ tarea.getNombre() }}
                        </div>
                    </div>
                {% else %}
                    <div class="col-span-full p-4 bg-yellow-50 text-yellow-700 rounded-lg border border-yellow-200">
                        No hay tareas guardadas todavía.
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="mt-8 bg-emerald-50 p-4 rounded-lg text-sm text-emerald-700 border border-emerald-200 flex items-center">
            <svg class="w-5 h-5 mr-2 animate-spin-slow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            <strong>Tip:</strong> Pulsa F5 para ver cómo se añade otra tarea automáticamente y se coloca en la cuadrícula.
        </div>

    </div>
{% endblock %}
