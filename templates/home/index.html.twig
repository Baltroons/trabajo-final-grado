{% extends 'base.html.twig' %}

{% block title %}Inicio - BrainHub{% endblock %}

{% block body %}
    {# Cabecera con el mensaje que pedía la plantilla #}
    <div class="bg-white rounded-2xl shadow-sm p-6 border-t-4 border-emerald-500 mb-8">
        <h1 class="text-3xl font-bold text-emerald-800 mb-2">{{ mensaje }}</h1>
        <p class="text-gray-600">Gestiona tus grupos de estudio y colabora con otros estudiantes.</p>
    </div>

    <div class="mb-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Mis Salas de Estudio:</h2>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            <div class="bg-white rounded-3xl shadow-sm border border-emerald-100 p-8 mb-8 flex justify-between items-center">
                <div>
                    <h1 class="text-3xl font-extrabold text-emerald-900 mb-2">¡Bienvenido a BrainHub!</h1>
                    <p class="text-gray-600">Aquí tienes tu panel personal para crear salas.</p>
                </div>
                {# BOTÓN PARA CREAR SALA #}
                <a href="{{ path('app_sala_new') }}" class="bg-emerald-600 hover:bg-emerald-700 text-white p-4 rounded-2xl shadow-lg transition-transform hover:scale-105">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                </a>
            </div>
            {# CAMBIO CRÍTICO: Usamos 'sala' en 'salas' en lugar de 'tarea' en 'tareas' #}
            {% for sala in salas %}
                <div class="p-5 border border-emerald-100 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex items-center justify-between mb-3">
                        <span class="text-[10px] font-bold px-2 py-1 bg-emerald-100 text-emerald-700 rounded-full uppercase">
                            {{ sala.categoria }}
                        </span>
                        {% if sala.creador == app.user %}
                            <span class="text-[10px] font-bold px-2 py-1 bg-amber-100 text-amber-700 rounded-full">PROPIETARIO</span>
                        {% endif %}
                    </div>

                    <h3 class="font-bold text-gray-900 mb-2">{{ sala.nombre }}</h3>
                    <p class="text-sm text-gray-500 line-clamp-2 mb-4">{{ sala.descripcion }}</p>

                    <a href="{{ path('app_sala_show', {'id': sala.id}) }}" class="w-full inline-block text-center bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-bold py-2 rounded-lg transition-colors">
                        Entrar a la sala
                    </a>
                </div>
            {% else %}
                {# Si no hay salas, mostramos este mensaje #}
                <div class="col-span-full py-12 text-center bg-emerald-50/50 rounded-2xl border-2 border-dashed border-emerald-200">
                    <p class="text-emerald-700 font-medium">Aún no participas en ninguna sala.</p>
                    <a href="{{ path('app_sala_index') }}" class="text-emerald-600 underline text-sm mt-2 inline-block">Explorar todas las salas</a>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
