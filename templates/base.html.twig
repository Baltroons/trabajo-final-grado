<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Mi Proyecto Symfony{% endblock %}</title>

    <script src="https://cdn.tailwindcss.com"></script>

    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-emerald-50 text-gray-800 font-sans min-h-screen flex flex-col">

<nav class="bg-emerald-600 text-white shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3">
        <div class="flex justify-between items-center">
            <a href="/" class="text-xl font-bold tracking-wider flex items-center gap-2">
                🌿 TareasApp
            </a>
        </div>
    </div>
</nav>

<main class="flex-grow max-w-6xl mx-auto px-4 py-8 w-full">
    {% block body %}{% endblock %}
</main>

<footer class="bg-emerald-900 text-emerald-100 text-center py-4 mt-auto">
    <p class="text-sm">&copy; {{ "now"|date("Y") }} - Desarrollado con Symfony, Twig y Tailwind.</p>
</footer>

</body>
</html>
