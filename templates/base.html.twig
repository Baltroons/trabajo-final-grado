<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Mi Proyecto Symfony{% endblock %}</title>

    <script src="https://cdn.tailwindcss.com"></script>

    {% block stylesheets %}{% endblock %}
</head>
{# AÑADIMOS: flex flex-col min-h-screen al body para que ocupe toda la pantalla #}
<body class="bg-gray-50 font-sans antialiased text-gray-900 flex flex-col min-h-screen">

{# --- BARRA DE NAVEGACIÓN SUPERIOR --- #}
<nav class="bg-emerald-800 shadow-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">

            {# Logo / Título #}
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-white font-bold text-xl hover:text-emerald-200 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                <span>BrainHub</span>
            </a>

            {# Botones Dinámicos #}
            <div class="flex items-center space-x-4">
                {% if app.user %}
                    {# ESTADO: LOGUEADO #}
                    <span class="text-emerald-100 hidden sm:inline-block">Hola, <strong class="text-white">{{ app.user.username }}</strong></span>

                    {# CAMBIO: Ahora apunta a 'app_login' en lugar de 'app_logout' #}
                    <a href="{{ path('app_login') }}" title="Ver mi cuenta" class="h-10 w-10 bg-emerald-600 rounded-full flex items-center justify-center text-white font-bold border-2 border-emerald-400 hover:bg-emerald-500 hover:border-white transition-all shadow-sm cursor-pointer">
                        {{ app.user.username|first|upper }}
                    </a>
                {% else %}
                    {# ESTADO: DESLOGUEADO #}
                    <a href="{{ path('app_login') }}" class="text-emerald-50 hover:text-white font-medium transition-colors">Iniciar sesión</a>
                    <a href="{{ path('app_register') }}" class="bg-emerald-500 hover:bg-emerald-400 text-white px-4 py-2 rounded-lg font-bold shadow-sm transition-all">Registrarse</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>

{# --- CONTENIDO PRINCIPAL --- #}
{# AÑADIMOS: flex-grow y w-full para que esta sección empuje al footer hacia abajo #}
<main class="flex-grow w-full max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    {% block body %}
        {% for message in app.flashes('success') %}
            <div class="bg-emerald-100 border border-emerald-400 text-emerald-700 px-4 py-3 rounded-xl mb-6 flex justify-between items-center shadow-sm animate-bounce">
                <span>{{ message }}</span>
                <button type="button" onclick="this.parentElement.remove()" class="font-bold">&times;</button>
            </div>
        {% endfor %}
    {% endblock %}
</main>

{# --- FOOTER --- #}
{# AÑADIMOS: w-full para asegurar que ocupe todo el ancho #}
<footer class="w-full bg-emerald-900 text-center py-4 text-emerald-300 text-sm mt-auto">
    &copy; 2026 - Plataforma de Estudio Colaborativo.
</footer>
</body>
</html>
