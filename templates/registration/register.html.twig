{% extends 'base.html.twig' %}

{% block title %}Registro - Plataforma de Estudio{% endblock %}

{% block body %}
    <div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-2xl shadow-xl border border-emerald-100">

            {# Encabezado #}
            <div class="text-center">
                <div class="mx-auto h-12 w-12 bg-emerald-100 rounded-full flex items-center justify-center mb-4">
                    <svg class="h-8 w-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="Write 18 20 2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <h2 class="text-3xl font-extrabold text-gray-900">Crear cuenta</h2>
                <p class="mt-2 text-sm text-gray-600">
                    Únete a la comunidad de estudio colaborativo
                </p>
            </div>

            {# Errores de validación generales #}
            {% if registrationForm.vars.errors|length > 0 %}
                <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-4">
                    {{ form_errors(registrationForm) }}
                </div>
            {% endif %}

            {{ form_start(registrationForm, {'attr': {'class': 'mt-8 space-y-6'}}) }}

            <div class="rounded-md shadow-sm space-y-4">
                {# Campo Username #}
                <div>
                    {{ form_label(registrationForm.username, 'Nombre de Usuario', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.username, {
                        'attr': {
                            'class': 'appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-emerald-500 focus:border-emerald-500 focus:z-10 sm:text-sm',
                            'placeholder': 'Ej: Estudiante123'
                        }
                    }) }}
                    <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.username) }}</div>
                </div>
                {# Campo Email #}
                <div>
                    {{ form_label(registrationForm.email, 'Correo Electrónico', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-emerald-500 focus:border-emerald-500 focus:z-10 sm:text-sm',
                            'placeholder': 'ejemplo@universidad.edu'
                        }
                    }) }}
                    <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.email) }}</div>
                </div>

                {# Campo Password #}
                <div>
                    {{ form_label(registrationForm.plainPassword, 'Contraseña', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {
                            'class': 'appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-emerald-500 focus:border-emerald-500 focus:z-10 sm:text-sm',
                            'placeholder': 'Mínimo 6 caracteres'
                        }
                    }) }}
                    <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.plainPassword) }}</div>
                </div>
            </div>

            {# Checkbox de Términos #}
            <div class="flex items-center">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'h-4 w-4 text-emerald-600 focus:ring-emerald-500 border-gray-300 rounded'}}) }}
                {{ form_label(registrationForm.agreeTerms, 'Acepto los términos de estudio colaborativo', {'label_attr': {'class': 'ml-2 block text-sm text-gray-900'}}) }}
            </div>

            <div>
                <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-lg text-white bg-emerald-600 hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-all shadow-md hover:shadow-lg">
                    Registrarse ahora
                </button>
            </div>

            <div class="text-center mt-4">
                <p class="text-sm text-gray-600">
                    ¿Ya tienes cuenta?
                    <a href="{{ path('app_login') }}" class="font-medium text-emerald-600 hover:text-emerald-500">
                        Inicia sesión aquí
                    </a>
                </p>
            </div>

            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}
