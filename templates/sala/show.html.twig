{% extends 'base.html.twig' %}

{% block title %}Sala: {{ sala.nombre }}{% endblock %}

{% block body %}
    <div class="max-w-6xl mx-auto">
        {# --- ENCABEZADO Y ACCIONES --- #}
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
                <a href="{{ path('app_sala_index') }}" class="text-emerald-600 hover:text-emerald-800 text-sm font-bold flex items-center gap-1 mb-2 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Volver al listado
                </a>
                <h1 class="text-4xl font-extrabold text-gray-900">{{ sala.nombre }}</h1>
                <span class="inline-block mt-2 px-3 py-1 bg-emerald-100 text-emerald-700 text-xs font-bold rounded-full uppercase tracking-widest">
                    {{ sala.categoria }}
                </span>
            </div>

            {% if app.user == sala.creador %}
                <div class="flex gap-3">
                    <a href="{{ path('app_sala_edit', {'id': sala.id}) }}" class="bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-xl font-semibold shadow-sm hover:bg-gray-50 transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        Editar
                    </a>
                    {{ include('sala/_delete_form.html.twig') }}
                </div>
            {% endif %}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            {# --- COLUMNA PRINCIPAL (CONTENIDO) --- #}
            <div class="lg:col-span-2 space-y-8">

                {# 1. Acerca de la sala #}
                <div class="bg-white rounded-3xl shadow-sm border border-emerald-100 p-8">
                    <h3 class="text-lg font-bold text-emerald-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Acerca de esta sala
                    </h3>
                    <p class="text-gray-600 leading-relaxed text-lg italic">
                        "{{ sala.descripcion ?: 'No hay una descripción detallada para esta sala todavía.' }}"
                    </p>
                    <div class="mt-8 pt-6 border-t border-gray-50 flex items-center gap-4">
                        <div class="h-12 w-12 bg-emerald-800 rounded-2xl flex items-center justify-center text-white font-bold text-xl shadow-inner">
                            {{ sala.creador.username|first|upper }}
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 uppercase font-bold tracking-tight">Anfitrión</p>
                            <p class="text-gray-900 font-bold">{{ sala.creador.username }}</p>
                        </div>
                    </div>
                </div>

                {# 2. Muro de Mensajes #}
                <div>
                    <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                        Muro de la comunidad
                    </h3>

                    {% if app.user in sala.miembros or app.user == sala.creador %}
                        <div class="bg-white rounded-2xl p-4 shadow-sm border border-emerald-50 mb-6">
                            {{ form_start(formMensaje) }}
                            {{ form_widget(formMensaje) }}
                            <div class="flex justify-end mt-2">
                                <button class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl text-sm font-bold transition-all">
                                    Enviar mensaje
                                </button>
                            </div>
                            {{ form_end(formMensaje) }}
                        </div>
                    {% endif %}

                    <div class="space-y-4">
                        {% for m in mensajes|sort((a, b) => b.fechaCreacion <=> a.fechaCreacion) %}
                            <div class="flex gap-3">
                                <div class="w-10 h-10 bg-gray-100 rounded-full flex-shrink-0 flex items-center justify-center font-bold text-emerald-700 border border-emerald-100">
                                    {{ m.autor.username|first|upper }}
                                </div>
                                <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex-grow">
                                    <div class="flex justify-between items-center mb-1">
                                        <span class="text-sm font-bold text-gray-800">{{ m.autor.username }}</span>
                                        <span class="text-[10px] text-gray-400">{{ m.fechaCreacion|date('d/m H:i') }}</span>
                                    </div>
                                    <p class="text-sm text-gray-600">{{ m.contenido }}</p>
                                </div>
                            </div>
                        {% else %}
                            <p class="text-center text-gray-400 text-sm py-8 bg-gray-50 rounded-2xl border border-dashed">No hay mensajes aún. ¡Rompe el hielo!</p>
                        {% endfor %}
                    </div>
                </div>

                {# 3. Materiales Compartidos #}
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
                    <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Materiales Compartidos
                    </h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                        {% for archivo in sala.archivos %}
                            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-2xl border border-gray-100 hover:border-emerald-200 transition-colors">
                                <div class="flex items-center gap-3">
                                    <div class="p-2 bg-emerald-100 text-emerald-700 rounded-lg">
                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"></path></svg>
                                    </div>
                                    <div class="overflow-hidden">
                                        <p class="text-sm font-bold text-gray-800 truncate" title="{{ archivo.nombreOriginal }}">{{ archivo.nombreOriginal }}</p>
                                        <p class="text-[10px] text-gray-400 font-medium">Por {{ archivo.subidoPor.username }}</p>
                                    </div>
                                </div>
                                <a href="{{ asset('uploads/' ~ archivo.nombreServidor) }}" target="_blank" class="flex-shrink-0 text-emerald-600 hover:text-emerald-800 font-bold text-xs bg-white px-3 py-1.5 rounded-lg border border-gray-200 shadow-sm transition-all">
                                    Descargar
                                </a>
                            </div>
                        {% else %}
                            <p class="col-span-full text-center text-gray-400 text-sm py-4 italic">No hay archivos compartidos todavía.</p>
                        {% endfor %}
                    </div>

                    {% if app.user in sala.miembros or app.user == sala.creador %}
                        <div class="mt-6 pt-6 border-t border-emerald-50">
                            <p class="text-[10px] text-emerald-600 mb-3 uppercase font-bold tracking-widest">Compartir nuevo material</p>
                            {{ form_start(formArchivo) }}
                            <div class="flex flex-col sm:flex-row gap-3">
                                <div class="flex-grow">
                                    {{ form_widget(formArchivo.documento) }}
                                </div>
                                <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-xl text-sm font-bold transition-all shadow-md">
                                    Subir
                                </button>
                            </div>
                            <div class="text-red-500 text-xs mt-1">{{ form_errors(formArchivo.documento) }}</div>
                            {{ form_end(formArchivo) }}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# --- COLUMNA LATERAL (ESTUDIANTES Y ESTADO) --- #}
            <div class="space-y-6">
                {# Estado de la suscripción #}
                <div class="bg-emerald-50 rounded-3xl p-6 border border-emerald-100">
                    {% if app.user == sala.creador %}
                        <div class="text-center">
                            <span class="bg-emerald-200 text-emerald-800 text-[10px] font-bold px-2 py-1 rounded-md mb-2 inline-block">MODO ADMIN</span>
                            <p class="text-emerald-800 text-sm font-medium">Eres el propietario de esta sala.</p>
                        </div>
                    {% elseif app.user in sala.miembros %}
                        <div class="flex items-center gap-3 text-emerald-700 font-bold text-sm">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            Miembro activo
                        </div>
                    {% else %}
                        <form action="{{ path('app_sala_join', {'id': sala.id}) }}" method="POST">
                            <button class="w-full bg-emerald-600 hover:bg-emerald-700 text-white py-3 rounded-2xl font-bold shadow-lg transition-all hover:scale-[1.02]">
                                Unirse para participar
                            </button>
                        </form>
                    {% endif %}
                </div>

                {# Lista de Estudiantes #}
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
                    <h3 class="font-bold text-gray-900 mb-4 flex items-center justify-between">
                        <span>Estudiantes</span>
                        <span class="bg-gray-100 text-gray-600 px-2 py-1 rounded-lg text-xs">{{ sala.miembros|length + 1 }}</span>
                    </h3>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-amber-400 rounded-full flex items-center justify-center text-white text-xs font-bold border-2 border-white shadow-sm">
                                {{ sala.creador.username|first|upper }}
                            </div>
                            <span class="text-sm font-semibold text-gray-800">{{ sala.creador.username }}</span>
                            <span class="text-[10px] text-amber-600 font-bold uppercase">Admin</span>
                        </li>
                        {% for miembro in sala.miembros %}
                            <li class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-emerald-500 rounded-full flex items-center justify-center text-white text-xs font-bold border-2 border-white shadow-sm">
                                    {{ miembro.username|first|upper }}
                                </div>
                                <span class="text-sm text-gray-600">{{ miembro.username }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

        </div>
    </div>
{% endblock %}
