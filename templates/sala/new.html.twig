{% extends 'base.html.twig' %}

{% block title %}Crear Nueva Sala{% endblock %}

{% block body %}
    <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-emerald-100">
            <div class="bg-emerald-800 p-8 text-white">
                <h1 class="text-2xl font-bold">Fundar una nueva Sala</h1>
                <p class="text-emerald-100 text-sm mt-2">Crea un espacio para compartir conocimientos con otros estudiantes.</p>
            </div>

            <div class="p-8">
                {{ form_start(form) }}
                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Nombre de la asignatura o grupo</label>
                        {{ form_widget(form.nombre) }}
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Categoría</label>
                        {{ form_widget(form.categoria) }}
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Descripción corta</label>
                        {{ form_widget(form.descripcion) }}
                    </div>

                    <div class="pt-4 flex items-center justify-end gap-4">
                        <a href="{{ path('app_home') }}" class="text-gray-500 hover:text-gray-700 font-medium text-sm">Cancelar</a>
                        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-md">
                            Crear Sala
                        </button>
                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
